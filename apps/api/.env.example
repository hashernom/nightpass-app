# Variables de entorno — NightPass API
# Copia este archivo a .env.local y completa los valores

# ── App ──────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── JWT (RS256) ───────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── OAuth Google ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ── Base de datos ─────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/nightpass
DIRECT_URL=postgresql://postgres:secret@localhost:5432/nightpass

# ── Redis ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── Seguridad QR ──────────────────────
QR_HMAC_SECRET=
QR_TTL_HOURS=24
COOKIE_SECRET=

# ── Stripe ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Wompi ─────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# ── Email ─────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=tickets@nightpass.co

# ── Monitoreo ─────────────────────────
SENTRY_DSN=

# NightPass API - Configuración de Desarrollo
# Copiar este archivo a .env.local y completar los valores

# ========== DATABASE ==========
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nightpass"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nightpass"

# ========== AUTHENTICATION ==========
# JWT Configuration (HS256 para desarrollo)
JWT_SECRET="dev-super-secret-jwt-key-change-in-production"

# Para RS256 (producción):
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ========== SECURITY ==========
# Rate Limiting
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en milisegundos

# Cookie Security
COOKIE_SECURE=false  # En desarrollo puede ser false, en producción true
COOKIE_SAME_SITE="lax"  # En desarrollo "lax", en producción "strict"

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# ========== APPLICATION ==========
# Server
PORT=3001
NODE_ENV="development"

# URLs
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# ========== PAYMENTS ==========
# Stripe (opcional para desarrollo)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Wompi (opcional para desarrollo)
WOMPI_PRIVATE_KEY="prv_test_..."
WOMPI_PUBLIC_KEY="pub_test_..."

# ========== REDIS ==========
# Redis para cache y rate limiting
REDIS_URL="redis://localhost:6379"

# ========== LOGGING ==========
LOG_LEVEL="debug"
LOG_PRETTY=true

# ========== FEATURES ==========
ENABLE_SWAGGER=true
ENABLE_CORS=true
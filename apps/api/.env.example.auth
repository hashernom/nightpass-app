# Configuración de Autenticación - NightPass API
# Copiar este archivo a .env.local y completar los valores

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Para RS256 (recomendado en producción):
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Rate Limiting
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en milisegundos

# Cookie Security
COOKIE_SECURE=true  # En producción debe ser true, en desarrollo puede ser false
COOKIE_SAME_SITE=strict

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Application URLs
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:3000